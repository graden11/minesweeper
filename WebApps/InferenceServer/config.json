{
  "server": {
    "port": 80,
    "name": "HttpServer",
    "threads": 4,
    "log_level": "INFO",
    "shutdown_timeout_ms": 30000
  },
  "logging": {
    "level": "INFO",
    "file": "server.log"
  },
  "redis": {
    "host": "redis",
    "port": 6379,
    "pool_size": 5
  },
  "mysql": {
    "host": "tcp://mysql:3306",
    "user": "",
    "password": "",
    "database": "inference_platform",
    "pool_size": 10
  },
  "models": {
    "global_labels_path": "models/imagenet_classes.txt",
    "engines": {
      "resnet50": {
        "type": "onnx",
        "version": "1",
        "path": "models/resnet50_classification.onnx",
        "task": "classification",
        "top_k": 5,
        "input": {
          "name": "input",
          "width": 224,
          "height": 224,
          "channels": 3,
          "mean": [0.485, 0.456, 0.406],
          "std": [0.229, 0.224, 0.225]
        },
        "output": {
          "name": "output"
        }
      },
      "resnet50_trt": {
        "type": "tensorrt",
        "version": "1",
        "path": "models/resnet50_classification.engine",
        "task": "classification",
        "top_k": 5,
        "input": {
          "name": "input",
          "width": 224,
          "height": 224,
          "channels": 3,
          "mean": [0.485, 0.456, 0.406],
          "std": [0.229, 0.224, 0.225]
        },
        "output": {
          "name": "output"
        }
      },
      "resnet50_int8": {
        "type": "tensorrt",
        "version": "1",
        "path": "models/resnet50_int8.engine",
        "task": "classification",
        "top_k": 5,
        "input": {
          "name": "input",
          "width": 224,
          "height": 224,
          "channels": 3,
          "mean": [0.485, 0.456, 0.406],
          "std": [0.229, 0.224, 0.225]
        },
        "output": {
          "name": "output"
        }
      }
    }
  },
  "batching": {
    "enabled": false,
    "max_batch_size": 8,
    "max_delay_ms": 10
  },
  "dynamic_engines": []
}
