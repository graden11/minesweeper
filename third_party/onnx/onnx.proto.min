syntax = "proto2";
package onnx;

// ── Version enum (required by ModelProto.ir_version) ──────────────
enum Version {
  _START_VERSION = 0;
  IR_VERSION = 0x000000000000000D;
}

// ── Minimal supporting types referenced by required messages ──────
message StringStringEntryProto {
  optional string key = 1;
  optional string value = 2;
}
message OperatorSetIdProto {
  optional string domain = 1;
  optional int64 version = 2;
}

// ── Minimal shells for types that appear in the ONNX binary but
//     whose content we don't need to inspect ────────────────────────
message AttributeProto    { /* don't care */ optional string name = 1; }
message NodeProto         { /* don't care */ repeated string input = 1; repeated string output = 2; }
message TensorProto       { /* don't care */ repeated int64 dims = 1; }
message SparseTensorProto { /* don't care */ }
message TensorAnnotation  { /* don't care */ }
message TrainingInfoProto { /* don't care */ }
message FunctionProto     { /* don't care */ }

// ── Messages we actually traverse ──────────────────────────────────
message TensorShapeProto {
  message Dimension {
    oneof value {
      int64 dim_value = 1;
      string dim_param = 2;
    }
    optional string denotation = 3;
  }
  repeated Dimension dim = 1;
}

message TypeProto {
  message Tensor {
    optional int32 elem_type = 1;
    optional TensorShapeProto shape = 2;
  }
  oneof value {
    Tensor tensor_type = 1;
  }
}

message ValueInfoProto {
  optional string name = 1;
  optional TypeProto type = 2;
}

message GraphProto {
  repeated NodeProto node = 1;
  repeated ValueInfoProto input = 11;
  repeated ValueInfoProto output = 12;
  // these fields may appear in any valid ONNX file:
  repeated TensorProto initializer = 5;
  repeated SparseTensorProto sparse_initializer = 15;
  repeated ValueInfoProto value_info = 13;
  repeated TensorAnnotation quantization_annotation = 14;
  repeated StringStringEntryProto metadata_props = 16;
}

message ModelProto {
  optional int64 ir_version = 1;
  optional GraphProto graph = 7;
  repeated OperatorSetIdProto opset_import = 8;
  repeated TrainingInfoProto training_info = 20;
  repeated FunctionProto functions = 25;
  repeated StringStringEntryProto metadata_props = 14;
}

// NOTE: deliberately NOT using LITE_RUNTIME so protobuf preserves
// unknown fields when we parse→modify→serialize real ONNX files.
